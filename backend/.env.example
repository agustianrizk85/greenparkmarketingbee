# Server
APP_PORT=8086
APP_ENV=development

# Database driver: "sqlite" (zero-setup local run) or "postgres" (production)
DB_DRIVER=sqlite
DB_PATH=./marketingflow.db

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=marketingflow
DB_SSLMODE=disable

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRY_HOURS=12

# Seed default account passwords (change after first login)
SEED_KADEP_PASSWORD=kadep123
SEED_STAFF_PASSWORD=staff123
SEED_VIEWER_PASSWORD=viewer123

# Meta (Facebook) Graph API
# Legacy single-token fallback — only used when NO OAuth account is connected.
META_ACCESS_TOKEN=
META_BUSINESS_ID=146016010006333
META_API_VERSION=v21.0
META_AD_ACCOUNT_ID=

# Meta OAuth (Facebook Login) — normally set from the UI (Akun Meta tab) and
# stored in the DB; these only seed defaults on first run. Multi-account: connect
# several accounts via OAuth and switch the active one in the UI.
META_APP_ID=
META_APP_SECRET=
# Must exactly match a "Valid OAuth Redirect URI" in the Meta App's Facebook Login settings.
META_REDIRECT_URI=http://localhost:8086/api/meta/oauth/callback
META_SCOPES=ads_read,pages_show_list,instagram_basic,instagram_manage_messages,whatsapp_business_management,business_management

# Server
APP_PORT=8086
APP_ENV=development

# Database driver: "sqlite" (zero-setup local run) or "postgres" (production)
DB_DRIVER=sqlite
DB_PATH=./marketingflow.db

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=marketingflow
DB_SSLMODE=disable

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRY_HOURS=12

# Seed default account passwords (change after first login)
SEED_KADEP_PASSWORD=kadep123
SEED_STAFF_PASSWORD=staff123
SEED_VIEWER_PASSWORD=viewer123
